msgid "Please verify your age"
msgstr "אנא אמת את הגיל שלך"

msgid "You must be of legal age to enter this site."
msgstr "עליך להיות בגיל החוקי כדי להיכנס לאתר זה."

msgid "Date of birth"
msgstr "תאריך לידה"

msgid "I am {age} or older"
msgstr "אני בן/בת {age} או יותר"

msgid "I am under {age}"
msgstr "אני מתחת לגיל {age}"

msgid "Enter site"
msgstr "כניסה לאתר"

msgid "Sorry, you can't enter"
msgstr "מצטערים, אינך רשאי להיכנס"

msgid "You are not old enough to view this site."
msgstr "אינך בגיל המתאים לצפות באתר זה."

msgid "Day"
msgstr "יום"

msgid "Month"
msgstr "חודש"

msgid "Mon"
msgstr "חודש"

msgid "Year"
msgstr "שנה"

msgid "Verification is disabled."
msgstr "אימות הגיל מושבת."

msgid "Verified. Welcome."
msgstr "מאומת. ברוך הבא."

msgid "Please enter a date of birth."
msgstr "אנא הזן תאריך לידה."

msgid "That date of birth doesn't look right."
msgstr "תאריך הלידה הזה לא נראה תקין."

msgid "You are not old enough to enter this site."
msgstr "אינך בגיל המתאים להיכנס לאתר זה."

msgid "Verified."
msgstr "מאומת."

msgid "Age Verification"
msgstr "אימות גיל"

msgid "Block under-age visitors from your public site with a customizable verification gate."
msgstr "חסום מבקרים מתחת לגיל מהאתר הציבורי שלך באמצעות שער אימות גיל הניתן להתאמה."

msgid "Behavior"
msgstr "התנהגות"

msgid "Enable gate"
msgstr "הפעלת שער"

msgid "Block under-age visitors on the public frontend."
msgstr "חסום מבקרים מתחת לגיל בצד הציבורי של האתר."

msgid "Minimum age"
msgstr "גיל מינימלי"

msgid "Visitors below this age cannot enter."
msgstr "מבקרים מתחת לגיל זה לא יוכלו להיכנס."

msgid "Verification mode"
msgstr "מצב אימות"

msgid "Date of birth — calculate age from the entered DOB."
msgstr "תאריך לידה — חישוב הגיל מתוך תאריך הלידה שהוזן."

msgid "Confirmation — visitor clicks \"I am over X\" / \"I am under X\"."
msgstr "אישור — המבקר לוחץ על \"אני מעל גיל X\" / \"אני מתחת לגיל X\"."

msgid "DOB input style"
msgstr "סגנון שדה תאריך לידה"

msgid "Native HTML5 date input (browser picker, follows the document language)."
msgstr "שדה תאריך HTML5 מקורי (בורר של הדפדפן, נצמד לשפת המסמך)."

msgid "Site-localized dropdowns (day / month / year — month names always follow the site language)."
msgstr "תפריטים נפתחים בשפת האתר (יום / חודש / שנה — שמות החודשים תמיד בשפת האתר)."

msgid "Cookie"
msgstr "עוגייה"

msgid "Cookie name"
msgstr "שם העוגייה"

msgid "Cookie lifetime (days)"
msgstr "אורך חיי העוגייה (ימים)"

msgid "SameSite"
msgstr "SameSite"

msgid "Messages"
msgstr "הודעות"

msgid "Use {age} to insert the configured minimum age."
msgstr "השתמש ב-{age} כדי להוסיף את הגיל המינימלי המוגדר."

msgid "Heading"
msgstr "כותרת"

msgid "Body text"
msgstr "תוכן"

msgid "DOB field label"
msgstr "תווית שדה תאריך הלידה"

msgid "\"Over X\" button label"
msgstr "תווית כפתור \"מעל X\""

msgid "\"Under X\" button label"
msgstr "תווית כפתור \"מתחת ל-X\""

msgid "Submit button label"
msgstr "תווית כפתור השליחה"

msgid "Rejection heading"
msgstr "כותרת דחייה"

msgid "Rejection body"
msgstr "תוכן דחייה"

msgid "Appearance — Logo"
msgstr "מראה — לוגו"

msgid "Logo"
msgstr "לוגו"

msgid "No logo selected"
msgstr "לא נבחר לוגו"

msgid "Choose image"
msgstr "בחירת תמונה"

msgid "Choose a verification screen logo"
msgstr "בחר לוגו למסך האימות"

msgid "Use this image"
msgstr "השתמש בתמונה זו"

msgid "Remove"
msgstr "הסר"

msgid "Logo max width (px)"
msgstr "רוחב מרבי של הלוגו (פיקסלים)"

msgid "Appearance — Background"
msgstr "מראה — רקע"

msgid "Background color"
msgstr "צבע רקע"

msgid "Background image"
msgstr "תמונת רקע"

msgid "No background image selected"
msgstr "לא נבחרה תמונת רקע"

msgid "Background image size"
msgstr "גודל תמונת הרקע"

msgid "Overlay opacity"
msgstr "אטימות שכבת הכיסוי"

msgid "Backdrop blur (px)"
msgstr "טשטוש הרקע (פיקסלים)"

msgid "Frosted-glass effect over the background. Set to 0 to disable."
msgstr "אפקט זכוכית מעורפלת מעל הרקע. הגדר ל-0 כדי לבטל."

msgid "Appearance — Panel"
msgstr "מראה — פאנל"

msgid "Panel color"
msgstr "צבע הפאנל"

msgid "Panel width (px)"
msgstr "רוחב הפאנל (פיקסלים)"

msgid "Panel padding (px)"
msgstr "מרווח פנימי של הפאנל (פיקסלים)"

msgid "Panel border radius (px)"
msgstr "רדיוס פינות הפאנל (פיקסלים)"

msgid "Appearance — Typography"
msgstr "מראה — טיפוגרפיה"

msgid "Font family"
msgstr "משפחת גופן"

msgid "CSS font stack. Leave empty to inherit a system default. Quotes, commas, hyphens, and spaces only."
msgstr "ערימת גופנים של CSS. השאר ריק כדי לרשת את ברירת המחדל של המערכת. רק מירכאות, פסיקים, מקפים ורווחים."

msgid "Body font size (px)"
msgstr "גודל גופן לתוכן (פיקסלים)"

msgid "Heading font size (px)"
msgstr "גודל גופן לכותרת (פיקסלים)"

msgid "Text color"
msgstr "צבע טקסט"

msgid "Text alignment"
msgstr "יישור טקסט"

msgid "Appearance — Controls"
msgstr "מראה — בקרים"

msgid "Accent color"
msgstr "צבע הדגשה"

msgid "Button border radius (px)"
msgstr "רדיוס פינות הכפתור (פיקסלים)"

msgid "Input border radius (px)"
msgstr "רדיוס פינות שדה הקלט (פיקסלים)"

msgid "Appearance — Custom CSS"
msgstr "מראה — CSS מותאם אישית"

msgid "Custom CSS"
msgstr "CSS מותאם אישית"

msgid "Scoped to the verification overlay. Tags and obvious script sequences are stripped on save. The following CSS variables are available:"
msgstr "מוגבל למסך האימות. תגיות ורצפי סקריפט ברורים מוסרים בשמירה. משתני CSS הבאים זמינים:"

msgid "Crawlers"
msgstr "סורקים"

msgid "Let search engines and social-media unfurlers see the real page so the site can be indexed and link previews work. The age gate stays in place for human visitors."
msgstr "אפשר למנועי חיפוש ולתצוגות מקדימות ברשתות חברתיות לראות את הדף האמיתי, כך שהאתר ייסרק ותצוגות הקישור יפעלו. שער אימות הגיל יישאר פעיל עבור מבקרים אנושיים."

msgid "Bypass for crawlers"
msgstr "עקיפה לסורקים"

msgid "Allow known search engines and social-media unfurlers to see the real page."
msgstr "אפשר למנועי חיפוש ידועים ולתצוגות מקדימות של רשתות חברתיות לראות את הדף האמיתי."

msgid "Crawler user agents"
msgstr "User agents של סורקים"

msgid "One token per line, case-insensitive substring match. Leave blank to use the built-in defaults:"
msgstr "ערך אחד בשורה, התאמה של מחרוזת חלקית ללא תלות ברישיות. השאר ריק כדי להשתמש בברירות המחדל המובנות:"

msgid "Exclusions"
msgstr "החרגות"

msgid "Excluded paths"
msgstr "נתיבים מוחרגים"

msgid "One path per line. Paths starting with the listed value bypass the gate (e.g. /privacy, /contact)."
msgstr "נתיב אחד בשורה. נתיבים המתחילים בערך הרשום עוקפים את השער (לדוגמה /privacy, /contact)."
