msgid "Please verify your age"
msgstr "Por favor, verifica tu edad"

msgid "You must be of legal age to enter this site."
msgstr "Debes tener la mayoría de edad para acceder a este sitio."

msgid "Date of birth"
msgstr "Fecha de nacimiento"

msgid "I am {age} or older"
msgstr "Tengo {age} años o más"

msgid "I am under {age}"
msgstr "Tengo menos de {age} años"

msgid "Enter site"
msgstr "Entrar en el sitio"

msgid "Sorry, you can't enter"
msgstr "Lo sentimos, no puedes acceder"

msgid "You are not old enough to view this site."
msgstr "No tienes la edad necesaria para ver este sitio."

msgid "Day"
msgstr "Día"

msgid "Month"
msgstr "Mes"

msgid "Mon"
msgstr "Mes"

msgid "Year"
msgstr "Año"

msgid "Verification is disabled."
msgstr "La verificación está desactivada."

msgid "Verified. Welcome."
msgstr "Verificado. Bienvenido."

msgid "Please enter a date of birth."
msgstr "Introduce una fecha de nacimiento."

msgid "That date of birth doesn't look right."
msgstr "Esa fecha de nacimiento no parece correcta."

msgid "You are not old enough to enter this site."
msgstr "No tienes la edad necesaria para acceder a este sitio."

msgid "Verified."
msgstr "Verificado."

msgid "Age Verification"
msgstr "Verificación de edad"

msgid "Block under-age visitors from your public site with a customizable verification gate."
msgstr "Bloquea a los visitantes menores de edad de tu sitio público con una verificación personalizable."

msgid "Behavior"
msgstr "Comportamiento"

msgid "Enable gate"
msgstr "Activar verificación"

msgid "Block under-age visitors on the public frontend."
msgstr "Bloquear a los visitantes menores de edad en el frontend público."

msgid "Minimum age"
msgstr "Edad mínima"

msgid "Visitors below this age cannot enter."
msgstr "Los visitantes por debajo de esta edad no podrán acceder."

msgid "Verification mode"
msgstr "Modo de verificación"

msgid "Date of birth — calculate age from the entered DOB."
msgstr "Fecha de nacimiento — calcular la edad a partir de la fecha introducida."

msgid "Confirmation — visitor clicks \"I am over X\" / \"I am under X\"."
msgstr "Confirmación — el visitante pulsa «Soy mayor de X» / «Soy menor de X»."

msgid "DOB input style"
msgstr "Estilo del campo de fecha de nacimiento"

msgid "Native HTML5 date input (browser picker, follows the document language)."
msgstr "Campo de fecha HTML5 nativo (selector del navegador, sigue el idioma del documento)."

msgid "Site-localized dropdowns (day / month / year — month names always follow the site language)."
msgstr "Listas desplegables localizadas (día / mes / año — los nombres de los meses siguen siempre el idioma del sitio)."

msgid "Cookie"
msgstr "Cookie"

msgid "Cookie name"
msgstr "Nombre de la cookie"

msgid "Cookie lifetime (days)"
msgstr "Duración de la cookie (días)"

msgid "SameSite"
msgstr "SameSite"

msgid "Messages"
msgstr "Mensajes"

msgid "Use {age} to insert the configured minimum age."
msgstr "Usa {age} para insertar la edad mínima configurada."

msgid "Heading"
msgstr "Título"

msgid "Body text"
msgstr "Cuerpo del texto"

msgid "DOB field label"
msgstr "Etiqueta del campo de fecha de nacimiento"

msgid "\"Over X\" button label"
msgstr "Etiqueta del botón «Mayor de X»"

msgid "\"Under X\" button label"
msgstr "Etiqueta del botón «Menor de X»"

msgid "Submit button label"
msgstr "Etiqueta del botón de envío"

msgid "Rejection heading"
msgstr "Título de rechazo"

msgid "Rejection body"
msgstr "Cuerpo del rechazo"

msgid "Appearance — Logo"
msgstr "Apariencia — Logotipo"

msgid "Logo"
msgstr "Logotipo"

msgid "No logo selected"
msgstr "Ningún logotipo seleccionado"

msgid "Choose image"
msgstr "Elegir imagen"

msgid "Choose a verification screen logo"
msgstr "Elige un logotipo para la pantalla de verificación"

msgid "Use this image"
msgstr "Usar esta imagen"

msgid "Remove"
msgstr "Eliminar"

msgid "Logo max width (px)"
msgstr "Ancho máximo del logotipo (px)"

msgid "Appearance — Background"
msgstr "Apariencia — Fondo"

msgid "Background color"
msgstr "Color de fondo"

msgid "Background image"
msgstr "Imagen de fondo"

msgid "No background image selected"
msgstr "Ninguna imagen de fondo seleccionada"

msgid "Background image size"
msgstr "Tamaño de la imagen de fondo"

msgid "Overlay opacity"
msgstr "Opacidad de la superposición"

msgid "Backdrop blur (px)"
msgstr "Desenfoque del fondo (px)"

msgid "Frosted-glass effect over the background. Set to 0 to disable."
msgstr "Efecto de cristal esmerilado sobre el fondo. Pon 0 para desactivar."

msgid "Appearance — Panel"
msgstr "Apariencia — Panel"

msgid "Panel color"
msgstr "Color del panel"

msgid "Panel width (px)"
msgstr "Ancho del panel (px)"

msgid "Panel padding (px)"
msgstr "Relleno del panel (px)"

msgid "Panel border radius (px)"
msgstr "Radio de los bordes del panel (px)"

msgid "Appearance — Typography"
msgstr "Apariencia — Tipografía"

msgid "Font family"
msgstr "Familia tipográfica"

msgid "CSS font stack. Leave empty to inherit a system default. Quotes, commas, hyphens, and spaces only."
msgstr "Pila de fuentes CSS. Déjalo vacío para heredar el valor por defecto del sistema. Solo comillas, comas, guiones y espacios."

msgid "Body font size (px)"
msgstr "Tamaño de fuente del cuerpo (px)"

msgid "Heading font size (px)"
msgstr "Tamaño de fuente del título (px)"

msgid "Text color"
msgstr "Color del texto"

msgid "Text alignment"
msgstr "Alineación del texto"

msgid "Appearance — Controls"
msgstr "Apariencia — Controles"

msgid "Accent color"
msgstr "Color de acento"

msgid "Button border radius (px)"
msgstr "Radio de los bordes del botón (px)"

msgid "Input border radius (px)"
msgstr "Radio de los bordes del campo (px)"

msgid "Appearance — Custom CSS"
msgstr "Apariencia — CSS personalizado"

msgid "Custom CSS"
msgstr "CSS personalizado"

msgid "Scoped to the verification overlay. Tags and obvious script sequences are stripped on save. The following CSS variables are available:"
msgstr "Limitado a la pantalla de verificación. Las etiquetas y secuencias de script evidentes se eliminan al guardar. Las siguientes variables CSS están disponibles:"

msgid "Crawlers"
msgstr "Rastreadores"

msgid "Let search engines and social-media unfurlers see the real page so the site can be indexed and link previews work. The age gate stays in place for human visitors."
msgstr "Permite que los motores de búsqueda y los previsualizadores de redes sociales vean la página real para que el sitio se indexe y las previsualizaciones de enlaces funcionen. La verificación de edad sigue activa para los visitantes humanos."

msgid "Bypass for crawlers"
msgstr "Omitir para rastreadores"

msgid "Allow known search engines and social-media unfurlers to see the real page."
msgstr "Permite que los motores de búsqueda y previsualizadores de redes sociales conocidos vean la página real."

msgid "Crawler user agents"
msgstr "User agents de rastreadores"

msgid "One token per line, case-insensitive substring match. Leave blank to use the built-in defaults:"
msgstr "Un valor por línea, coincidencia de subcadena que no distingue mayúsculas. Déjalo vacío para usar los valores por defecto incorporados:"

msgid "Exclusions"
msgstr "Exclusiones"

msgid "Excluded paths"
msgstr "Rutas excluidas"

msgid "One path per line. Paths starting with the listed value bypass the gate (e.g. /privacy, /contact)."
msgstr "Una ruta por línea. Las rutas que empiezan por el valor indicado omiten la verificación (por ejemplo, /privacy, /contact)."
