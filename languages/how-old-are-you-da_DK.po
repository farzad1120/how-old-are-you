msgid "Please verify your age"
msgstr "Bekræft din alder"

msgid "You must be of legal age to enter this site."
msgstr "Du skal være myndig for at få adgang til dette site."

msgid "Date of birth"
msgstr "Fødselsdato"

msgid "I am {age} or older"
msgstr "Jeg er {age} år eller ældre"

msgid "I am under {age}"
msgstr "Jeg er under {age} år"

msgid "Enter site"
msgstr "Gå ind på siden"

msgid "Sorry, you can't enter"
msgstr "Beklager, du kan ikke få adgang"

msgid "You are not old enough to view this site."
msgstr "Du er ikke gammel nok til at se dette site."

msgid "Day"
msgstr "Dag"

msgid "Month"
msgstr "Måned"

msgid "Mon"
msgstr "Måned"

msgid "Year"
msgstr "År"

msgid "Verification is disabled."
msgstr "Verifikation er deaktiveret."

msgid "Verified. Welcome."
msgstr "Bekræftet. Velkommen."

msgid "Please enter a date of birth."
msgstr "Indtast en fødselsdato."

msgid "That date of birth doesn't look right."
msgstr "Den fødselsdato ser ikke rigtig ud."

msgid "You are not old enough to enter this site."
msgstr "Du er ikke gammel nok til at få adgang til dette site."

msgid "Verified."
msgstr "Bekræftet."

msgid "Age Verification"
msgstr "Aldersverifikation"

msgid "Block under-age visitors from your public site with a customizable verification gate."
msgstr "Bloker mindreårige besøgende fra din offentlige side med en tilpasselig aldersverifikation."

msgid "Behavior"
msgstr "Adfærd"

msgid "Enable gate"
msgstr "Aktivér verifikation"

msgid "Block under-age visitors on the public frontend."
msgstr "Bloker mindreårige besøgende på det offentlige frontend."

msgid "Minimum age"
msgstr "Minimumsalder"

msgid "Visitors below this age cannot enter."
msgstr "Besøgende under denne alder kan ikke få adgang."

msgid "Verification mode"
msgstr "Verifikationstilstand"

msgid "Date of birth — calculate age from the entered DOB."
msgstr "Fødselsdato — beregn alder ud fra den indtastede fødselsdato."

msgid "Confirmation — visitor clicks \"I am over X\" / \"I am under X\"."
msgstr "Bekræftelse — den besøgende klikker på »Jeg er over X« / »Jeg er under X«."

msgid "DOB input style"
msgstr "Stil for fødselsdatofelt"

msgid "Native HTML5 date input (browser picker, follows the document language)."
msgstr "Native HTML5-datofelt (browservælger, følger dokumentets sprog)."

msgid "Site-localized dropdowns (day / month / year — month names always follow the site language)."
msgstr "Sitelokaliserede rullelister (dag / måned / år — månedsnavne følger altid sitets sprog)."

msgid "Cookie"
msgstr "Cookie"

msgid "Cookie name"
msgstr "Cookienavn"

msgid "Cookie lifetime (days)"
msgstr "Cookielevetid (dage)"

msgid "SameSite"
msgstr "SameSite"

msgid "Messages"
msgstr "Beskeder"

msgid "Use {age} to insert the configured minimum age."
msgstr "Brug {age} til at indsætte den konfigurerede minimumsalder."

msgid "Heading"
msgstr "Overskrift"

msgid "Body text"
msgstr "Brødtekst"

msgid "DOB field label"
msgstr "Etiket for fødselsdatofelt"

msgid "\"Over X\" button label"
msgstr "Etiket for »Over X«-knap"

msgid "\"Under X\" button label"
msgstr "Etiket for »Under X«-knap"

msgid "Submit button label"
msgstr "Etiket for send-knap"

msgid "Rejection heading"
msgstr "Overskrift ved afvisning"

msgid "Rejection body"
msgstr "Tekst ved afvisning"

msgid "Appearance — Logo"
msgstr "Udseende — Logo"

msgid "Logo"
msgstr "Logo"

msgid "No logo selected"
msgstr "Intet logo valgt"

msgid "Choose image"
msgstr "Vælg billede"

msgid "Choose a verification screen logo"
msgstr "Vælg et logo til verifikationsskærmen"

msgid "Use this image"
msgstr "Brug dette billede"

msgid "Remove"
msgstr "Fjern"

msgid "Logo max width (px)"
msgstr "Maksimal logobredde (px)"

msgid "Appearance — Background"
msgstr "Udseende — Baggrund"

msgid "Background color"
msgstr "Baggrundsfarve"

msgid "Background image"
msgstr "Baggrundsbillede"

msgid "No background image selected"
msgstr "Intet baggrundsbillede valgt"

msgid "Background image size"
msgstr "Størrelse på baggrundsbillede"

msgid "Overlay opacity"
msgstr "Overlejringens uigennemsigtighed"

msgid "Backdrop blur (px)"
msgstr "Sløring af baggrund (px)"

msgid "Frosted-glass effect over the background. Set to 0 to disable."
msgstr "Mat glaseffekt over baggrunden. Sæt til 0 for at deaktivere."

msgid "Appearance — Panel"
msgstr "Udseende — Panel"

msgid "Panel color"
msgstr "Panelfarve"

msgid "Panel width (px)"
msgstr "Panelbredde (px)"

msgid "Panel padding (px)"
msgstr "Panelafstand (px)"

msgid "Panel border radius (px)"
msgstr "Panelkantradius (px)"

msgid "Appearance — Typography"
msgstr "Udseende — Typografi"

msgid "Font family"
msgstr "Skrifttypefamilie"

msgid "CSS font stack. Leave empty to inherit a system default. Quotes, commas, hyphens, and spaces only."
msgstr "CSS-skrifttypestak. Lad være tom for at arve systemets standard. Kun citationstegn, kommaer, bindestreger og mellemrum."

msgid "Body font size (px)"
msgstr "Skriftstørrelse for brødtekst (px)"

msgid "Heading font size (px)"
msgstr "Skriftstørrelse for overskrift (px)"

msgid "Text color"
msgstr "Tekstfarve"

msgid "Text alignment"
msgstr "Tekstjustering"

msgid "Appearance — Controls"
msgstr "Udseende — Kontroller"

msgid "Accent color"
msgstr "Accentfarve"

msgid "Button border radius (px)"
msgstr "Kantradius for knap (px)"

msgid "Input border radius (px)"
msgstr "Kantradius for inputfelt (px)"

msgid "Appearance — Custom CSS"
msgstr "Udseende — Brugerdefineret CSS"

msgid "Custom CSS"
msgstr "Brugerdefineret CSS"

msgid "Scoped to the verification overlay. Tags and obvious script sequences are stripped on save. The following CSS variables are available:"
msgstr "Begrænset til verifikationsoverlejringen. Tags og åbenlyse scriptsekvenser fjernes ved gem. Følgende CSS-variabler er tilgængelige:"

msgid "Crawlers"
msgstr "Crawlere"

msgid "Let search engines and social-media unfurlers see the real page so the site can be indexed and link previews work. The age gate stays in place for human visitors."
msgstr "Lad søgemaskiner og social media-link-forhåndsvisninger se den rigtige side, så sitet kan indekseres, og linkforhåndsvisninger virker. Aldersverifikationen forbliver aktiv for menneskelige besøgende."

msgid "Bypass for crawlers"
msgstr "Spring over for crawlere"

msgid "Allow known search engines and social-media unfurlers to see the real page."
msgstr "Tillad kendte søgemaskiner og social media-forhåndsvisninger at se den rigtige side."

msgid "Crawler user agents"
msgstr "User agents for crawlere"

msgid "One token per line, case-insensitive substring match. Leave blank to use the built-in defaults:"
msgstr "Ét token pr. linje, ikke versalfølsom substring-sammenligning. Lad være tom for at bruge de indbyggede standardværdier:"

msgid "Exclusions"
msgstr "Undtagelser"

msgid "Excluded paths"
msgstr "Ekskluderede stier"

msgid "One path per line. Paths starting with the listed value bypass the gate (e.g. /privacy, /contact)."
msgstr "Én sti pr. linje. Stier, der begynder med den angivne værdi, omgår verifikationen (f.eks. /privacy, /contact)."
