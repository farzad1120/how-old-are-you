{
    "name": "farzad1120/how-old-are-you",
    "description": "Block under-age visitors from the public WordPress frontend with a customizable age-verification gate.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": ["wordpress", "plugin", "age-verification", "age-gate", "compliance"],
    "homepage": "https://github.com/farzad1120/how-old-are-you",
    "authors": [
        {
            "name": "Farzad Zarasvand",
            "email": "farzad@wedevelop.nl"
        }
    ],
    "require": {
        "php": ">=7.4",
        "composer/installers": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.10",
        "wp-coding-standards/wpcs": "^3.1",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "brain/monkey": "^2.6"
    },
    "autoload": {
        "psr-4": {
            "HOAY\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HOAY\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit"
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
